#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────
#  CandyBarV2 — one-shot launcher
#  Usage:  ./run
# ─────────────────────────────────────────────────────────────────
set -e
cd "$(dirname "$0")"

PYTHON="./venv/bin/python3"
PIP="./venv/bin/pip"
RCC="./venv/bin/pyside6-rcc"

# ── 1. Create venv if missing ────────────────────────────────────
if [ ! -f "$PYTHON" ]; then
    echo "[run] Creating virtual environment..."
    python3 -m venv venv
fi

# ── 2. Install / sync dependencies ──────────────────────────────
echo "[run] Checking dependencies..."
$PIP install -q -r requirements.txt

# ── 3. Compile QRC resources ────────────────────────────────────
if [ -f "$RCC" ]; then
    echo "[run] Compiling Qt resources..."
    $RCC app/imports/resource.qrc -o app/imports/resource_rc.py
else
    echo "[run] Warning: pyside6-rcc not found in virtual environment, skipping compilation."
fi

# ── 4. Launch ───────────────────────────────────────────────────
echo "[run] Starting CandyBarV2..."
exec $PYTHON main.py
